<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EDA Transistor & Device Level Simulator</title>
    <style>
        body {
            background-color: #0b0e14;
            color: #adbac7;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        h1 { color: #539bf5; margin-bottom: 5px; font-size: 1.8rem; }
        .subtitle { color: #768390; font-size: 0.9em; margin-bottom: 20px; }
        .container { display: flex; gap: 20px; max-width: 1300px; width: 100%; }
        .panel { background: #22272e; border: 1px solid #444c56; border-radius: 6px; padding: 20px; flex: 1; }
        .canvas-container { flex: 1.5; display: flex; flex-direction: column; align-items: center; background: #1c2128; border: 1px solid #444c56; border-radius: 6px; padding: 20px; }
        canvas { background: #000; border: 1px solid #539bf5; border-radius: 4px; box-shadow: 0 0 15px rgba(83, 155, 245, 0.15); }
        .dsl-box { background: #1c2128; border-left: 4px solid #f69d50; padding: 10px; font-family: monospace; font-size: 0.8em; overflow-x: auto; color: #f6a052; margin-bottom: 15px; border-radius: 0 4px 4px 0; }
        .control-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; font-weight: bold; font-size: 0.85em; color: #768390; }
        input[type="range"] { width: 100%; accent-color: #539bf5; background: #2d333b; }
        .btn { background-color: #347d39; color: white; border: none; padding: 10px 20px; font-size: 0.95em; border-radius: 6px; cursor: pointer; width: 100%; transition: 0.2s; font-weight: bold; }
        .btn:hover { background-color: #46954a; }
        .console { background: #101419; border: 1px solid #444c56; border-radius: 4px; font-family: monospace; padding: 10px; height: 140px; overflow-y: auto; width: 100%; box-sizing: border-box; margin-top: 15px; font-size: 0.8em; color: #57ab5a; line-height: 1.4; }
        .status-badge { display: inline-block; padding: 2px 6px; background: #3162a2; color: #fff; border-radius: 3px; font-size: 0.8em; margin-bottom: 10px; }
    </style>
</head>
<body>

    <h1>EDA Transistor-Level DSL Simulator</h1>
    <div class="subtitle">基於 9宮格隨機變異與 Z-Laplace 頻域調諧之電晶體模擬晶片運行（2026 奈米製程實驗室）</div>

    <div class="container">
        <div class="panel">
            <span class="status-badge">SPICE / EDA Runtime Engine Ready</span>
            <h3>輸入之電晶體級 DSL 描述</h3>
            <div class="dsl-box">
// 階段 1：掃描與調諧反轉五階環形振盪器暫態注入
tune_brush_scanned(wing_glucose_acute_angled_inclined_EMV.engine_inversed_five_tick(tube_IMV()_code(), tube_INV()_passage_queue()))

// 階段 2：針對晶格幾何變異進行 9宮格隨機 Monte Carlo 補償與拉普拉斯極點修正
IMV_z-laplace_tune.stochastic_9-cells_session_chained(4-outspirt_bi_rendered_maze_info()_capacity(switch_function_complement(IMV()_code(projected_rhombus_turbine.cache_universe_link().IMAGE_kernel().skeleton_set()))))
            </div>
            
            <h3>EDA 模擬參數調節 (Simulation Knobs)</h3>
            <div class="control-group">
                <label id="lbl-tick">5-Stage Ring Oscillator Tick Freq: 5.0 GHz</label>
                <input type="range" id="param-tick" min="1" max="10" value="5" step="0.5">
            </div>
            <div class="control-group">
                <label id="lbl-capacity">Gate Channel Carrier Density (Capacity): 60</label>
                <input type="range" id="param-capacity" min="20" max="150" value="60">
            </div>
            <div class="control-group">
                <label id="lbl-noise">Stochastic Lattice Variation (9-Cells Noise): 25%</label>
                <input type="range" id="param-noise" min="5" max="80" value="25">
            </div>
            
            <button class="btn" id="btn-trigger">重新運行蒙地卡羅 (Run Monte Carlo SPICE)</button>
            
            <div class="console" id="console-out">[EDA SPICE] 網表（Netlist）與佈局解析完成。等待模擬訊號輸入...</div>
        </div>

        <div class="canvas-container">
            <h3>Transistor Micro-Domain Visualization</h3>
            <canvas id="simCanvas" width="550" height="420"></canvas>
            <div style="margin-top:12px; font-size:0.8em; color:#768390; text-align: center; width: 100%;">
                <span style="color:#57ab5a;">■</span> 綠線：IMV/INV 通道極板邊界 &nbsp;&nbsp;
                <span style="color:#539bf5;">■</span> 藍色幾何：FinFET 菱形渦輪閘極骨架<br>
                <span style="color:#f47067;">■</span> 紅點：N-Type 電子 (IMV) &nbsp;&nbsp;
                <span style="color:#f69d50;">■</span> 黃點：P-Type 電電洞 (INV) 在 9宮格晶格變異中擴散
            </div>
        </div>
    </div>

    <script>
        const canvas = document.getElementById('simCanvas');
        const ctx = canvas.getContext('2d');
        const consoleOut = document.getElementById('console-out');

        const paramTick = document.getElementById('param-tick');
        const paramCapacity = document.getElementById('param-capacity');
        const paramNoise = document.getElementById('param-noise');
        const btnTrigger = document.getElementById('btn-trigger');

        let time = 0;
        let carriers = [];

        function log(msg) {
            const t = new Date().toLocaleTimeString();
            consoleOut.innerHTML += `[${t}] ${msg}<br>`;
            consoleOut.scrollTop = consoleOut.scrollHeight;
        }

        // 初始化半導體通道載子 (Carriers)
        function initCarriers() {
            carriers = [];
            const count = parseInt(paramCapacity.value);
            for(let i=0; i<count; i++) {
                carriers.push({
                    x: canvas.width / 2 + (Math.random() - 0.5) * 160,
                    y: canvas.height / 2 + (Math.random() - 0.5) * 160,
                    vx: (Math.random() - 0.5) * 1.5,
                    vy: (Math.random() - 0.5) * 1.5,
                    type: Math.random() > 0.5 ? 'electron' : 'hole', // IMV code vs INV queue
                    gridId: Math.floor(Math.random() * 9) // stochastic 9-cells
                });
            }
        }

        // 滑桿連動更新
        paramTick.oninput = () => document.getElementById('lbl-tick').innerText = `5-Stage Ring Oscillator Tick Freq: ${parseFloat(paramTick.value).toFixed(1)} GHz`;
        paramCapacity.oninput = () => {
            document.getElementById('lbl-capacity').innerText = `Gate Channel Carrier Density (Capacity): ${paramCapacity.value}`;
            initCarriers();
        };
        paramNoise.oninput = () => document.getElementById('lbl-noise').innerText = `Stochastic Lattice Variation (9-Cells Noise): ${paramNoise.value}%`;

        btnTrigger.onclick = () => {
            log("⚡ 觸發暫態調諧分析 tune_brush_scanned()...");
            log("🔬 載入幾何骨架特徵：projected_rhombus_turbine.skeleton_set()");
            log("📈 執行 Z-Laplace 極點補償與 9宮格隨機變異收斂計算...");
            initCarriers();
        };

        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // 基礎時脈步進（對應五刻度引擎速度）
            const tickSpeed = parseFloat(paramTick.value);
            time += tickSpeed * 0.015;

            // 1. 繪製 9宮格晶格邊界 (stochastic_9-cells 物理區塊)
            ctx.strokeStyle = '#22272e';
            ctx.lineWidth = 1;
            const w3 = canvas.width / 3;
            const h3 = canvas.height / 3;
            for(let i=1; i<3; i++) {
                ctx.beginPath(); ctx.moveTo(w3 * i, 0); ctx.lineTo(w3 * i, canvas.height); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(0, h3 * i); ctx.lineTo(canvas.width, h3 * i); ctx.stroke();
            }

            // 2. 繪製傾斜銳角的電晶體主通道 (acute-angled inclined EMV channel)
            ctx.strokeStyle = '#347d39';
            ctx.lineWidth = 4;
            ctx.shadowBlur = 0;
            ctx.beginPath();
            // 上通道邊界 (Source 側注入管線)
            ctx.moveTo(40, 60); ctx.lineTo(canvas.width - 40, 110);
            // 下通道邊界 (Drain 側注入管線)
            ctx.moveTo(40, canvas.height - 60); ctx.lineTo(canvas.width - 40, canvas.height - 110);
            ctx.stroke();

            // 3. 繪製核心元件幾何：菱形渦輪閘極結構 (projected_rhombus_turbine 佈局骨架)
            ctx.save();
            ctx.translate(canvas.width / 2, canvas.height / 2);
            // 模擬震盪器的高頻相位偏轉
            ctx.rotate(Math.sin(time * 0.5) * 0.15); 
            
            // 繪製微米級晶格菱形
            ctx.strokeStyle = '#539bf5';
            ctx.lineWidth = 2.5;
            ctx.beginPath();
            ctx.moveTo(0, -80);
            ctx.lineTo(130, 0);
            ctx.lineTo(0, 80);
            ctx.lineTo(-130, 0);
            ctx.closePath();
            ctx.stroke();

            // 繪製 IMAGE_kernel 快取核心 (閘極介電層 Gate Oxide 電場強度調變)
            let fieldPulse = 20 + Math.sin(time * 2) * 8;
            let gradient = ctx.createRadialGradient(0, 0, 5, 0, 0, fieldPulse);
            gradient.addColorStop(0, 'rgba(83, 155, 245, 0.6)');
            gradient.addColorStop(1, 'rgba(83, 155, 245, 0)');
            ctx.fillStyle = gradient;
            ctx.beginPath(); ctx.arc(0, 0, fieldPulse, 0, Math.PI * 2); ctx.fill();
            ctx.restore();

            // 4. 更新並擴散半導體載子粒子行為 (Laplace 飄移與隨機變異擴散)
            const noiseLevel = parseInt(paramNoise.value) / 100;
            
            carriers.forEach(p => {
                // 受 5-tick 震盪器與 Z-Laplace 極點影響的波動力學
                // 模擬 4-outspirit 的四向發散力與晶格雜訊
                const angle = (time + p.gridId * 45) * (Math.PI / 180);
                const driftX = Math.sin(time + p.gridId) * tickSpeed * 0.3;
                
                p.x += p.vx + driftX + (Math.random() - 0.5) * noiseLevel * 5;
                p.y += p.vy + (Math.random() - 0.5) * noiseLevel * 5;

                // 物理邊界碰撞 (防止跑出電晶體井通道區)
                if (p.x < 50 || p.x > canvas.width - 50) p.vx *= -1;
                if (p.y < 80 || p.y > canvas.height - 80) p.vy *= -1;

                // 渲染 N型電子與 P型電洞
                ctx.fillStyle = p.type === 'electron' ? '#f47067' : '#f69d50';
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.type === 'electron' ? 3.5 : 4.5, 0, Math.PI * 2);
                ctx.fill();
            });

            // 隨機在主控台輸出 EDA 求解狀態，增加模擬真實感
            if(Math.random() < 0.01) {
                const volts = (1.2 + Math.sin(time)*0.05).toFixed(3);
                log(`[Solver] 暫態牛頓法迭代收斂。V_gate = ${volts}V, 閘極漏電流補償中...`);
            }

            requestAnimationFrame(draw);
        }

        // 初始化並開機
        initCarriers();
        log("🚀 EDA 模擬核心初始化成功。已載入高階 FinFET 菱形晶格架構模型。");
        draw();
    </script>
</body>
</html>
